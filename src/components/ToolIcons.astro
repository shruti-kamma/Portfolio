---
interface Props {
	tools: Array<'figma' | 'github'>;
}

const { tools } = Astro.props;

const ICON_BG: Record<string, string> = {
	figma: '#1e1e1e',
	github: '#181717',
};
---

<ul class="tool-icons">
	{
		tools.map((tool) => (
			<li class="tool-icons__item" style={`background: ${ICON_BG[tool]}`} title={tool}>
				{tool === 'figma' && (
					<svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
						<path fill="#F24E1E" d="M8 24a4 4 0 0 0 4-4v-4H8a4 4 0 0 0 0 8Z" />
						<path fill="#A259FF" d="M4 12a4 4 0 0 1 4-4h4v8H8a4 4 0 0 1-4-4Z" />
						<path fill="#F24E1E" d="M4 4a4 4 0 0 1 4-4h4v8H8a4 4 0 0 1-4-4Z" />
						<path fill="#FF7262" d="M12 0h4a4 4 0 0 1 0 8h-4V0Z" />
						<path fill="#1ABCFE" d="M20 12a4 4 0 1 1-8 0 4 4 0 0 1 8 0Z" />
					</svg>
				)}
				{tool === 'github' && (
					<svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
						<path
							fill="#fff"
							d="M12 .5C5.37.5 0 5.87 0 12.5c0 5.3 3.44 9.8 8.21 11.39.6.11.82-.26.82-.58 0-.29-.01-1.06-.02-2.08-3.34.73-4.04-1.61-4.04-1.61-.55-1.39-1.34-1.76-1.34-1.76-1.09-.75.08-.73.08-.73 1.21.08 1.84 1.24 1.84 1.24 1.07 1.84 2.81 1.31 3.5 1 .11-.78.42-1.31.76-1.61-2.67-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.12-.3-.54-1.52.12-3.18 0 0 1.01-.32 3.3 1.23a11.5 11.5 0 0 1 6 0c2.29-1.55 3.3-1.23 3.3-1.23.66 1.66.24 2.88.12 3.18.77.84 1.24 1.91 1.24 3.22 0 4.61-2.81 5.63-5.49 5.92.43.37.81 1.1.81 2.22 0 1.6-.02 2.89-.02 3.29 0 .32.22.7.83.58C20.56 22.3 24 17.8 24 12.5 24 5.87 18.63.5 12 .5Z"
						/>
					</svg>
				)}
			</li>
		))
	}
</ul>

<style>
	.tool-icons {
		display: flex;
		gap: 0.5rem;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.tool-icons__item {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 40px;
		height: 40px;
		border-radius: 8px;
	}
</style>
