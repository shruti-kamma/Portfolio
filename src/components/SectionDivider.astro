---
interface Props {
	label?: string;
}

const { label } = Astro.props;
---

<div class="section-divider">
	<svg class="section-divider__line" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
		<line x1="0" y1="0.5" x2="100%" y2="0.5" stroke="currentColor" stroke-width="1" stroke-dasharray="5 5" stroke-linecap="round" />
	</svg>
	{label && <span>{label}</span>}
</div>

<style>
	.section-divider {
		position: relative;
		display: flow-root;
		margin-block: 3rem;
		text-align: center;
	}

	.section-divider__line {
		position: absolute;
		top: 50%;
		left: 0;
		width: 100%;
		height: 1px;
		transform: translateY(-50%);
		overflow: visible;
		pointer-events: none;
		color: var(--color-text);
	}

	.section-divider span {
		position: relative;
		display: inline-block;
		padding-inline: 1rem;
		background: var(--color-bg);
		font-size: 1.5rem;
		font-weight: 500;
	}
</style>
