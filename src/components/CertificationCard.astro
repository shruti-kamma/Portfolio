---
interface Props {
	title: string;
	issuer: string;
	date: string;
	courseCount?: string;
	verifyUrl?: string;
	image?: string;
	imagePosition?: string;
}

const { title, issuer, date, courseCount, verifyUrl, image, imagePosition = '50% 50%' } = Astro.props;
const dialogId = `cert-preview-${title.replace(/\s+/g, '-').toLowerCase()}`;
---

<div class="cert-card">
	{
		image ? (
			<button type="button" class="cert-card__image" aria-label={`View full ${title} certificate`} data-cert-trigger={dialogId}>
				<img src={image} alt="" class="cert-card__image-img" style={`object-position: ${imagePosition}`} />
				<span class="cert-card__image-overlay" aria-hidden="true" />
				<span class="cert-card__image-zoom" aria-hidden="true">
					<svg viewBox="0 0 24 24" width="16" height="16">
						<circle cx="10.5" cy="10.5" r="6.5" fill="none" stroke="currentColor" stroke-width="2" />
						<path d="M10.5 7.5v6M7.5 10.5h6" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
						<path d="M15.5 15.5 21 21" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
					</svg>
				</span>
			</button>
		) : (
			<span class="cert-card__image" aria-hidden="true" />
		)
	}

	<svg class="cert-card__divider" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
		<line x1="0.5" y1="0" x2="0.5" y2="100%" stroke="currentColor" stroke-width="1" stroke-dasharray="5 5" stroke-linecap="round" />
	</svg>

	<div class="cert-card__body">
		<p class="cert-card__title">{title}</p>
		<p class="cert-card__meta">{issuer} · {date}</p>
		{courseCount && <p class="cert-card__courses">{courseCount}</p>}
		{
			verifyUrl && (
				<a class="cert-card__verify" href={verifyUrl} target="_blank" rel="noreferrer">
					Verify →
				</a>
			)
		}
	</div>
</div>

{
	image && (
		<dialog id={dialogId} class="cert-dialog">
			<button type="button" class="cert-dialog__close" data-cert-close={dialogId} aria-label="Close">
				✕
			</button>
			<img src={image} alt={title} class="cert-dialog__image" />
		</dialog>
	)
}

<style>
	.cert-card {
		display: flex;
		align-items: center;
		gap: 1.25rem;
		padding: 0.75rem;
		border: 1px solid var(--color-accent);
		border-radius: var(--radius-control);
	}

	.cert-card__image {
		position: relative;
		display: block;
		flex: 0 0 clamp(140px, 32%, 220px);
		aspect-ratio: 5 / 4;
		padding: 0;
		border: 1px solid var(--color-accent);
		overflow: hidden;
		background: var(--color-bg);
		cursor: zoom-in;
	}

	.cert-card__image-img {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: 0% 50%;
	}

	.cert-card__image-overlay {
		position: absolute;
		inset: 0;
		background: rgba(123, 150, 71, 0.35);
	}

	.cert-card__image-zoom {
		position: absolute;
		right: 0.4rem;
		bottom: 0.4rem;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 24px;
		height: 24px;
		border-radius: 50%;
		background: var(--color-bg);
		color: var(--color-text);
	}

	.cert-card__divider {
		align-self: stretch;
		width: 1px;
		flex-shrink: 0;
		overflow: visible;
		color: var(--color-text);
	}

	.cert-card__body {
		min-width: 0;
	}

	.cert-card__title {
		margin: 0 0 0.25rem;
		font-weight: 600;
	}

	.cert-card__meta {
		margin: 0;
		font-size: 0.875rem;
	}

	.cert-card__courses {
		margin: 0.25rem 0 0;
		font-size: 0.875rem;
		color: var(--color-accent);
	}

	.cert-card__verify {
		display: inline-block;
		margin-top: 0.5rem;
		font-weight: 600;
		font-size: 0.9rem;
		text-decoration: none;
		color: var(--color-accent);
	}

	.cert-dialog {
		position: fixed;
		max-width: 90vw;
		max-height: 90vh;
		padding: 0;
		border: none;
		border-radius: var(--radius-control);
		background: var(--color-bg);
	}

	.cert-dialog::backdrop {
		background: rgba(0, 0, 0, 0.6);
	}

	.cert-dialog__image {
		display: block;
		max-width: 90vw;
		max-height: 90vh;
		width: auto;
		height: auto;
	}

	.cert-dialog__close {
		position: absolute;
		top: 0.5rem;
		right: 0.5rem;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 32px;
		height: 32px;
		border: none;
		border-radius: 50%;
		background: var(--color-bg);
		font-size: 1rem;
		cursor: pointer;
	}
</style>

<script>
	document.querySelectorAll<HTMLButtonElement>('[data-cert-trigger]').forEach((trigger) => {
		trigger.addEventListener('click', () => {
			const id = trigger.getAttribute('data-cert-trigger');
			const dialog = id && document.getElementById(id);
			if (dialog instanceof HTMLDialogElement) dialog.showModal();
		});
	});

	document.querySelectorAll<HTMLButtonElement>('[data-cert-close]').forEach((btn) => {
		btn.addEventListener('click', () => {
			const id = btn.getAttribute('data-cert-close');
			const dialog = id && document.getElementById(id);
			if (dialog instanceof HTMLDialogElement) dialog.close();
		});
	});

	document.querySelectorAll<HTMLDialogElement>('.cert-dialog').forEach((dialog) => {
		dialog.addEventListener('click', (event) => {
			if (event.target === dialog) dialog.close();
		});
	});
</script>
