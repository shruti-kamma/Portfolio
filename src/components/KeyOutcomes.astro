---
interface Outcome {
	shape: 'triangle-up' | 'circle' | 'triangle-down';
	label: string;
}

interface Props {
	outcomes: Outcome[];
}

const { outcomes } = Astro.props;
---

<div class="key-outcomes">
	{
		outcomes.map((outcome, i) => (
			<>
				{i === 1 && (
						<p class="key-outcomes__heading">
							Key
							<br />
							Outcomes
						</p>
					)}
				<div class="key-outcomes__shape">
					{outcome.shape === 'circle' && (
						<svg viewBox="0 0 100 100" aria-hidden="true">
							<circle
								cx="50"
								cy="50"
								r="45"
								fill="none"
								stroke="currentColor"
								stroke-width="1"
								stroke-dasharray="5.049 5.049"
								stroke-linecap="round"
								vector-effect="non-scaling-stroke"
							/>
						</svg>
					)}
					{outcome.shape === 'triangle-up' && (
						<svg viewBox="0 0 100 100" aria-hidden="true">
							<polygon
								points="50,5 95,95 5,95"
								fill="none"
								stroke="currentColor"
								stroke-width="1"
								stroke-dasharray="5.022 5.022"
								stroke-linecap="round"
								stroke-linejoin="round"
								vector-effect="non-scaling-stroke"
							/>
						</svg>
					)}
					{outcome.shape === 'triangle-down' && (
						<svg viewBox="0 0 100 100" aria-hidden="true">
							<polygon
								points="5,5 95,5 50,95"
								fill="none"
								stroke="currentColor"
								stroke-width="1"
								stroke-dasharray="5.022 5.022"
								stroke-linecap="round"
								stroke-linejoin="round"
								vector-effect="non-scaling-stroke"
							/>
						</svg>
					)}
					<span class="key-outcomes__label">
						{outcome.label.split(' ')[0]}
						<br />
						{outcome.label.split(' ').slice(1).join(' ')}
					</span>
				</div>
			</>
		))
	}
</div>

<style>
	.key-outcomes {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 4rem;
		margin-block: 3rem;
	}

	.key-outcomes__heading {
		margin: 0;
		font-size: 1.5rem;
		font-weight: 500;
		line-height: 1.2;
		text-align: left;
	}

	.key-outcomes__shape {
		position: relative;
		width: clamp(140px, 14vw, 200px);
		color: var(--color-text);
	}

	.key-outcomes__shape svg {
		display: block;
		width: 100%;
		height: auto;
		overflow: visible;
	}

	.key-outcomes__label {
		position: absolute;
		inset: 0;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 0 1rem;
		text-align: center;
		font-size: 1rem;
		font-weight: 600;
		line-height: 1.3;
		color: var(--card-accent);
	}
</style>
