---
import DashedBorder from './DashedBorder.astro';

interface Props {
	src?: string;
	alt?: string;
	solid?: boolean;
}

const { src, alt = '', solid = false } = Astro.props;
---

<span class={`framed-image ${solid && !src ? 'framed-image--solid' : ''}`}>
	<DashedBorder />
	{src && <img src={src} alt={alt} />}
	<slot />
</span>

<style>
	.framed-image {
		position: relative;
		display: block;
		width: 100%;
		height: 100%;
		background: var(--color-bg);
	}

	.framed-image--solid {
		background: var(--card-accent);
	}

	.framed-image img {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
	}
</style>
