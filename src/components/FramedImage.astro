---
import DashedBorder from './DashedBorder.astro';

interface Props {
	src?: string;
	alt?: string;
}

const { src, alt = '' } = Astro.props;
---

<span class="framed-image">
	<DashedBorder />
	{src && <img src={src} alt={alt} />}
	<slot />
</span>

<style>
	.framed-image {
		position: relative;
		display: block;
		width: 100%;
		height: 100%;
		background: var(--color-bg);
	}

	.framed-image img {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
	}
</style>
