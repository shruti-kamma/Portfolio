<svg class="dashed-border" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
	<rect
		x="0"
		y="0"
		width="100%"
		height="100%"
		fill="none"
		stroke="currentColor"
		stroke-width="1"
		stroke-dasharray="5 5"
		stroke-linecap="round"
		stroke-linejoin="round"
	/>
</svg>

<style>
	.dashed-border {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		overflow: visible;
		pointer-events: none;
		color: var(--color-text);
	}
</style>
