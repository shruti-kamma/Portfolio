---
interface Props {
	learnings: string[];
}

const { learnings } = Astro.props;
---

<div class="learnings">
	<div class="learnings__circle">
		<svg viewBox="0 0 200 200" aria-hidden="true">
			<circle
				cx="100"
				cy="100"
				r="95"
				fill="none"
				stroke="currentColor"
				stroke-width="1"
				stroke-dasharray="4.974 4.974"
				stroke-linecap="round"
				vector-effect="non-scaling-stroke"
			/>
		</svg>
		<span class="learnings__label">Learnings</span>
	</div>

	<ol class="learnings__list">
		{
			learnings.map((item) => (
				<li>
					{item}
					<svg class="learnings__line" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
						<line
							x1="0"
							y1="0.5"
							x2="100%"
							y2="0.5"
							stroke="currentColor"
							stroke-width="1"
							stroke-dasharray="5 5"
							stroke-linecap="round"
						/>
					</svg>
				</li>
			))
		}
	</ol>
</div>

<style>
	.learnings {
		display: flex;
		justify-content: center;
		align-items: center;
		gap: 3rem;
		margin-block: 3rem 5rem;
	}

	.learnings__circle {
		position: relative;
		flex: 0 0 clamp(140px, 15vw, 180px);
		color: var(--color-text);
	}

	.learnings__circle svg {
		display: block;
		width: 100%;
		height: auto;
		overflow: visible;
	}

	.learnings__label {
		position: absolute;
		inset: 0;
		display: flex;
		align-items: center;
		justify-content: center;
		font-weight: 500;
	}

	.learnings__list {
		flex: 0 0 27.5rem;
		margin: 0;
		padding: 0;
		list-style: none;
		counter-reset: learnings;
	}

	.learnings__list li {
		position: relative;
		display: flex;
		align-items: baseline;
		gap: 0.5rem;
		margin-bottom: 0.75rem;
		padding-bottom: 0.5rem;
		font-size: 1rem;
		counter-increment: learnings;
	}

	.learnings__list li::before {
		content: counter(learnings) '.';
		font-weight: 600;
	}

	.learnings__line {
		position: absolute;
		left: 0;
		bottom: 0;
		width: 100%;
		height: 1px;
		overflow: visible;
		pointer-events: none;
		color: var(--color-text);
	}
</style>
