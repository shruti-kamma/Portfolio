---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectHero from '../../components/ProjectHero.astro';
import ProjectMeta from '../../components/ProjectMeta.astro';
import KeyOutcomes from '../../components/KeyOutcomes.astro';
import ProcessStep from '../../components/ProcessStep.astro';
import Learnings from '../../components/Learnings.astro';
import FramedImage from '../../components/FramedImage.astro';
import ToolIcons from '../../components/ToolIcons.astro';
import ProjectNav from '../../components/ProjectNav.astro';

export async function getStaticPaths() {
	const projects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);
	return projects.map((project, i) => ({
		params: { slug: project.id },
		props: { project, next: projects[(i + 1) % projects.length] },
	}));
}

const { project, next } = Astro.props;
const { title, accent, heroImage, context, scope, duration, role, tools, outcomes, process, finalDesignImage, learnings } = project.data;
---

<BaseLayout title={`${title} — Shruti Kamma`}>
	<div class="site-container">
		<article class="project-detail" style={`--card-accent: var(--color-${accent})`}>
			<ProjectHero title={title} image={heroImage} />

			<ProjectMeta context={context} scope={scope} duration={duration} role={role} tools={tools} />

			<KeyOutcomes outcomes={outcomes} />

			<div class="project-detail__divider">
				<svg class="project-detail__divider-line" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
					<line
						x1="0"
						y1="0.5"
						x2="100%"
						y2="0.5"
						stroke="currentColor"
						stroke-width="1"
						stroke-dasharray="5 5"
						stroke-linecap="round"
					/>
				</svg>
				<span>The Process</span>
			</div>

			{
				process.map((step, i) => (
					<ProcessStep
						number={i + 1}
						problem={step.problem}
						description={step.description}
						image={step.image}
						imageSide={i % 2 === 0 ? 'left' : 'right'}
					/>
				))
			}

			<div class="project-detail__divider">
				<svg class="project-detail__divider-line" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
					<line
						x1="0"
						y1="0.5"
						x2="100%"
						y2="0.5"
						stroke="currentColor"
						stroke-width="1"
						stroke-dasharray="5 5"
						stroke-linecap="round"
					/>
				</svg>
			</div>

			<section class="project-detail__final">
				<div class="project-detail__final-header">
					<h2>Final Design</h2>
					<ToolIcons tools={tools} />
				</div>
				<div class="project-detail__final-image">
					<FramedImage src={finalDesignImage} alt={`${title} final design`} solid />
				</div>
			</section>

			<Learnings learnings={learnings} />

			<ProjectNav nextSlug={next.id} nextTitle={next.data.title} nextAccent={next.data.accent} />
		</article>
	</div>
</BaseLayout>

<style>
	.project-detail {
		margin-bottom: 5rem;
	}

	.project-detail__divider {
		position: relative;
		display: flow-root;
		margin-block: 3rem;
		text-align: center;
	}

	.project-detail__divider-line {
		position: absolute;
		top: 50%;
		left: 0;
		width: 100%;
		height: 1px;
		transform: translateY(-50%);
		overflow: visible;
		pointer-events: none;
		color: var(--color-text);
	}

	.project-detail__divider span {
		position: relative;
		display: inline-block;
		padding-inline: 1rem;
		background: var(--color-bg);
		font-size: 1.5rem;
		font-weight: 500;
	}

	.project-detail__final {
		margin-bottom: 3rem;
	}

	.project-detail__final-header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		margin-bottom: 1rem;
	}

	.project-detail__final-header h2 {
		margin: 0;
		font-size: 1.5rem;
		font-weight: 500;
	}

	.project-detail__final-image {
		aspect-ratio: 16 / 9;
	}
</style>
